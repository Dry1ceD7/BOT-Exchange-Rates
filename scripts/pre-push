#!/usr/bin/env bash
# =========================================================================
#  BOT Exchange Rate Processor — Pre-Push Version Audit Hook
# =========================================================================
#  This hook dynamically extracts the project version from main.py and
#  verifies that README.md is in sync. If mismatched, it auto-patches
#  README.md and stages the fix before the push proceeds.
#
#  Install:  cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#  Or run:   ./scripts/install-hooks.sh
# =========================================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BOLD}  BOT Exrate — Pre-Push Version Audit${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# ── 1. Extract canonical version from main.py ─────────────────────────────
# Pattern: "BOT Exchange Rate Processor (vX.Y.Z)"
MAIN_VERSION=$(sed -n 's/.*\(v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' main.py | head -1)

if [ -z "$MAIN_VERSION" ]; then
    echo -e "${RED}✗ FATAL: Could not extract version from main.py${NC}"
    echo "  Expected pattern: 'BOT Exchange Rate Processor (vX.Y.Z)'"
    exit 1
fi

echo -e "  Source of truth (main.py):  ${GREEN}${MAIN_VERSION}${NC}"

# ── 2. Extract version number (without 'v' prefix) ───────────────────────
VERSION_NUM="${MAIN_VERSION#v}"  # e.g. "2.4.0"

# ── 3. Check README.md ───────────────────────────────────────────────────
README_VERSION=$(sed -n 's/.*Version \([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' README.md | head -1)

if [ -z "$README_VERSION" ]; then
    echo -e "${YELLOW}⚠ WARNING: Could not find 'Version X.Y.Z' in README.md${NC}"
    README_VERSION="NOT_FOUND"
fi

echo -e "  README.md version:         ${CYAN}${README_VERSION}${NC}"

MISMATCH=0

if [ "$README_VERSION" != "$VERSION_NUM" ]; then
    echo -e "${YELLOW}  → Mismatch detected. Auto-patching README.md...${NC}"
    if [ "$README_VERSION" = "NOT_FOUND" ]; then
        echo -e "${RED}  ✗ Cannot auto-patch: no 'Version X.Y.Z' pattern found in README.md${NC}"
        echo -e "${RED}    Please manually add a version line and retry.${NC}"
        exit 1
    fi
    # Replace the old version with the new one
    sed -i '' "s/Version ${README_VERSION}/Version ${VERSION_NUM}/g" README.md
    git add README.md
    echo -e "${GREEN}  ✓ README.md patched: ${README_VERSION} → ${VERSION_NUM}${NC}"
    MISMATCH=1
fi

# ── 4. Cross-check other critical files ──────────────────────────────────
FILES_TO_CHECK=(
    "gui/app.py"
    "core/engine.py"
    "core/api_client.py"
    "CLAUDE.md"
    "requirements.txt"
)

for f in "${FILES_TO_CHECK[@]}"; do
    if [ -f "$f" ]; then
        if ! grep -q "$MAIN_VERSION" "$f" 2>/dev/null; then
            echo -e "${YELLOW}  ⚠ ${f} may not contain ${MAIN_VERSION}${NC}"
        fi
    fi
done

# ── 5. Final verdict ────────────────────────────────────────────────────
echo ""
if [ $MISMATCH -eq 1 ]; then
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}  README.md was auto-patched and staged.${NC}"
    echo -e "${YELLOW}  Please amend your commit:  git commit --amend --no-edit${NC}"
    echo -e "${YELLOW}  Then push again.${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
else
    echo -e "${GREEN}  ✓ All version strings are in sync: ${MAIN_VERSION}${NC}"
    echo -e "${GREEN}  ✓ Push approved.${NC}"
fi
echo ""
